<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="onClick"
            type="com.into.websoso.ui.feedDetail.FeedDetailClickListener" />

        <variable
            name="feedDetail"
            type="com.into.websoso.ui.feedDetail.model.FeedDetailModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_feed_detail_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="@{(cl_feed_detail_header) -> onClick.onFeedDetailClick(cl_feed_detail_header)}">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_feed_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_feed_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:onClick="@{() -> onClick.onProfileClick(feedDetail.feed.user.id, feedDetail.feed.isMyFeed)}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_feed_profile"
                    cornerRadius="@{12f}"
                    loads3ImageUrl="@{feedDetail.feed.user.avatarImage}"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:srcCompat="@tools:sample/avatars" />

                <TextView
                    android:id="@+id/tv_feed_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:maxLines="1"
                    android:text="@{feedDetail.feed.user.nickname}"
                    android:textAppearance="@style/title2"
                    android:textColor="@color/black"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/iv_feed_profile"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="세훈군" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_feed_created_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{feedDetail.feed.formattedCreatedDate}"
                android:textAppearance="@style/body5"
                android:textColor="@color/black"
                app:layout_constraintBottom_toBottomOf="@+id/cl_feed_profile"
                app:layout_constraintStart_toEndOf="@+id/cl_feed_profile"
                app:layout_constraintTop_toTopOf="@+id/cl_feed_profile" />

            <TextView
                android:id="@+id/tv_feed_is_modified"
                isVisible="@{feedDetail.feed.modified}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/feed_is_modified"
                android:textAppearance="@style/body5"
                android:textColor="@color/gray_200_949399"
                app:layout_constraintBottom_toBottomOf="@+id/tv_feed_created_date"
                app:layout_constraintStart_toEndOf="@+id/tv_feed_created_date"
                app:layout_constraintTop_toTopOf="@+id/tv_feed_created_date" />

            <TextView
                android:id="@+id/tv_feed_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp"
                android:breakStrategy="simple"
                android:gravity="top"
                android:text="@{feedDetail.feed.content}"
                android:textAppearance="@style/body2"
                android:textColor="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_feed_profile"
                tools:text="최근 잼께 봤던 무협 소설 목록 진짜들만 골라봤어요 애매한 건 빼고 주로 무협 중에서도 회귀물로 골라봤어요 왜냐면 내가 회귀물을 좋아하기 때문에 최근 잼께 봤던 무협 소설 목록 진짜들만 골라봤어요최근 잼께 봤던 무협 소설 목록 진짜들을 가 회귀물을 좋아하기 때문에 최근 잼께 봤습니다 몇글자 까지 될지 모르겠네요" />

            <androidx.compose.ui.platform.ComposeView
                android:id="@+id/cv_feed_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:isVisible="@{!feedDetail.feed.imageUrls.empty}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_feed_content" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_feed_novel_info"
                isVisible="@{!feedDetail.feed.novel.nothing}"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/btn_feed_novel_info"
                android:clipToOutline="true"
                android:onClick="@{() -> onClick.onNovelInfoClick(feedDetail.feed.novel.id)}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cv_feed_image">

                <ImageView
                    android:id="@+id/iv_feed_novel_thumbnail"
                    loadImageUrl="@{feedDetail.novel.thumbnail}"
                    android:layout_width="86dp"
                    android:layout_height="124dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:src="@drawable/img_loading_thumbnail" />

                <ImageView
                    android:id="@+id/iv_feed_detail_novel_genre"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:layout_constraintBottom_toBottomOf="@id/iv_feed_novel_thumbnail"
                    app:layout_constraintEnd_toEndOf="@id/iv_feed_novel_thumbnail"
                    tools:src="@drawable/ic_bl" />

                <TextView
                    android:id="@+id/tv_feed_novel_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="30dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@{feedDetail.feed.novel.title}"
                    android:textAppearance="@style/title2"
                    android:textColor="@color/black"
                    app:layout_constraintBottom_toTopOf="@id/ll_feed_detail_ratings"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/iv_feed_novel_thumbnail"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    tools:text="화산귀환화산귀환화산귀환화산귀환화산귀환화산귀환화산귀환화산귀환화산귀환화산귀환" />

                <LinearLayout
                    android:id="@+id/ll_feed_detail_ratings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toTopOf="@id/tv_feed_detail_novel_description"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tv_feed_novel_name"
                    app:layout_constraintTop_toBottomOf="@id/tv_feed_novel_name"
                    app:layout_constraintVertical_chainStyle="packed">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_feed_detail_writer_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingEnd="8dp"
                        app:isVisible="@{!feedDetail.novel.isWriterRatingNoting}">

                        <TextView
                            android:id="@+id/tv_feed_detail_writer_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{feedDetail.feed.user.nickname}"
                            android:textAppearance="@style/body5"
                            android:textColor="@color/gray_300_52515F"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/iv_feed_detail_writer_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/ic_feed_detail_writer_star"
                            app:layout_constraintBottom_toBottomOf="@id/tv_feed_detail_writer_rating"
                            app:layout_constraintStart_toEndOf="@id/tv_feed_detail_writer_rating"
                            app:layout_constraintTop_toTopOf="@id/tv_feed_detail_writer_rating" />

                        <TextView
                            android:id="@+id/tv_feed_detail_writer_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:text="@{@string/feed_score_count(feedDetail.novel.feedWriterNovelRating)}"
                            android:textAppearance="@style/body5_2"
                            android:textColor="@color/secondary_100_FF675D"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/iv_feed_detail_writer_score"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="4.0" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_feed_detail_novel_all_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:isVisible="@{!feedDetail.novel.isRatingNoting}">

                        <TextView
                            android:id="@+id/tv_feed_detail_novel_all_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="전체"
                            android:textAppearance="@style/body5"
                            android:textColor="@color/gray_200_949399"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/iv_feed_detail_all_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_feed_detail_novel_star"
                            app:layout_constraintBottom_toBottomOf="@id/tv_feed_detail_novel_all_rating"
                            app:layout_constraintStart_toEndOf="@id/tv_feed_detail_novel_all_rating"
                            app:layout_constraintTop_toTopOf="@id/tv_feed_detail_novel_all_rating" />

                        <TextView
                            android:id="@+id/tv_feed_detail_all_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:text="@{@string/feed_score_count(feedDetail.feed.novel.rating)}"
                            android:textAppearance="@style/body5"
                            android:textColor="@color/gray_200_949399"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/iv_feed_detail_all_rating"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="4.0" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_feed_detail_novel_description"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="30dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@{feedDetail.novel.description}"
                    android:textAppearance="@style/body5"
                    android:textColor="@color/gray_300_52515F"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tv_feed_novel_name"
                    app:layout_constraintTop_toBottomOf="@id/ll_feed_detail_ratings"
                    tools:text="소설 줄거리 내용입니다...ㅇㅁㅇㄹㅁㄴㅇㄹㅁㄴㅇㄹㅁㄴㅇㄹㅁㄴㅇㄹㄴㅁㅇㄹㄴㅁㅇㄹㄴㅁㄹㄴ" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_feed_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:onClick="@{(cl_feed_like) -> onClick.onLikeButtonClick(cl_feed_like, feedDetail.feed.id)}"
                app:layout_constraintBottom_toTopOf="@+id/view_feed_indicator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_feed_novel_info"
                app:layout_constraintVertical_bias="0.0">

                <ImageView
                    android:id="@+id/iv_feed_thumb_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/btn_feed_thumb_up"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_feed_thumb_up_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"
                    android:maxLines="1"
                    android:text="@{String.valueOf(feedDetail.feed.likeCount)}"
                    android:textAppearance="@style/body2"
                    android:textColor="@color/gray_200_949399"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_feed_thumb_up"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/iv_feed_thumb_up"
                    app:layout_constraintTop_toTopOf="@+id/iv_feed_thumb_up"
                    tools:text="32" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_feed_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/cl_feed_like"
                app:layout_constraintStart_toEndOf="@+id/cl_feed_like"
                app:layout_constraintTop_toTopOf="@+id/cl_feed_like">

                <ImageView
                    android:id="@+id/iv_feed_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/ic_comment"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_feed_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"
                    android:maxLines="1"
                    android:text="@{String.valueOf(feedDetail.feed.commentCount)}"
                    android:textAppearance="@style/body2"
                    android:textColor="@color/gray_200_949399"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_feed_comment"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/iv_feed_comment"
                    app:layout_constraintTop_toTopOf="@+id/iv_feed_comment"
                    tools:text="32" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/view_feed_indicator"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_feed_indicator"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/view_feed_detail_divider"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginBottom="20dp"
            android:background="@color/gray_50_F4F5F8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_feed_detail" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
